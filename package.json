{
  "name": "liquidglass-react",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:wasm": "cd engine && emcmake cmake -B build-web && cmake --build build-web -j4",
    "watch:wasm": "nodemon --watch engine/src -e cpp,h --exec 'npm run build:wasm'",
    "dev:vite": "vite",
    "dev": "concurrently \"npm run watch:wasm\" \"npm run dev:vite\"",
    "build": "npm run build:wasm && vite build"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-live-reload": "^3.0.0",
    "vite-plugin-top-level-await": "^1.4.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
