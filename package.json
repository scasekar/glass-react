{
  "name": "liquidglass-react",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:wasm": "cd engine && emcmake cmake -B build-web && cmake --build build-web -j4",
    "watch:wasm": "nodemon --watch engine/src -e cpp,h --exec 'npm run build:wasm'",
    "dev:vite": "vite",
    "dev": "concurrently \"npm run watch:wasm\" \"npm run dev:vite\"",
    "dev:demo": "vite --config vite.demo.config.ts",
    "build:demo": "vite build --config vite.demo.config.ts",
    "build:lib": "vite build",
    "build": "npm run build:wasm && npm run build:lib",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@webgpu/types": "^0.1.69",
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-live-reload": "^3.0.0",
    "vite-plugin-top-level-await": "^1.4.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
